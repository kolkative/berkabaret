---
import Base from '../../../layouts/Base.astro';
import { supabaseAdmin } from '../../../lib/supabase';

const { order_code } = Astro.params;
const { data: order } = await supabaseAdmin
  .from('orders')
  .select('*, events(slug)')
  .eq('order_code', order_code)
  .single();
---
<Base title="Pembayaran Expired — BERKABARET">
  <div class="max-w-lg mx-auto px-4 py-24 text-center">
    <div class="text-6xl mb-6">⏰</div>
    <h1 class="font-display font-extrabold text-3xl mb-3 text-red-400">Waktu Habis</h1>
    <p class="text-gray-400 mb-8">
      Maaf, batas waktu pembayaran untuk order <span class="font-mono text-white">{order_code}</span> sudah habis.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      {order?.events?.slug && (
        <a href={`/events/${order.events.slug}/register`}
          class="bg-brand-600 hover:bg-brand-500 text-white font-semibold px-6 py-3 rounded-xl transition-colors">
          Beli Tiket Lagi
        </a>
      )}
      <a href="/events" class="bg-dark-800 hover:bg-dark-700 border border-dark-600/50 text-white font-medium px-6 py-3 rounded-xl transition-colors">
        Lihat Event Lain
      </a>
    </div>
  </div>
</Base>

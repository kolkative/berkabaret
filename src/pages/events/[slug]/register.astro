---
import Base from '../../../layouts/Base.astro';
import { supabaseAdmin } from '../../../lib/supabase';
import type { Event } from '../../../lib/supabase';

const { slug } = Astro.params;
const { data: event } = await supabaseAdmin
  .from('events')
  .select('*')
  .eq('slug', slug)
  .eq('is_active', true)
  .single();

if (!event) return Astro.redirect('/events');
const e = event as Event;
const availableTypes = e.ticket_types?.filter((t: any) => t.quota - t.sold > 0) ?? [];
if (availableTypes.length === 0) return Astro.redirect(`/events/${slug}`);
---
<Base title={`Beli Tiket — ${e.title}`}>
  <div class="max-w-2xl mx-auto px-4 py-16">
    <!-- Back -->
    <a href={`/events/${slug}`} class="inline-flex items-center gap-2 text-gray-500 hover:text-white text-sm mb-8 transition-colors">
      ← Kembali ke detail event
    </a>

    <h1 class="font-display font-extrabold text-3xl mb-2">Beli Tiket</h1>
    <p class="text-gray-500 mb-10">{e.title}</p>

    <form id="ticketForm" class="space-y-6">
      <!-- Pilih tipe tiket -->
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-3">Jenis Tiket</label>
        <div class="space-y-2" id="ticketTypeGroup">
          {availableTypes.map((t: any, i: number) => (
            <label class="ticket-option flex items-center justify-between border border-dark-600/50 rounded-xl p-4 cursor-pointer hover:border-brand-600/50 transition-colors has-[:checked]:border-brand-500 has-[:checked]:bg-brand-900/20">
              <div class="flex items-center gap-3">
                <input type="radio" name="ticket_type_id" value={t.id} data-name={t.name} data-price={t.price} class="accent-brand-500" required checked={i === 0} />
                <div>
                  <p class="text-white font-medium text-sm">{t.name}</p>
                  <p class="text-gray-500 text-xs">Sisa {t.quota - t.sold} tiket</p>
                </div>
              </div>
              <span class="font-mono text-brand-400 font-semibold text-sm">
                {t.price === 0 ? 'Gratis' : `Rp ${t.price.toLocaleString('id-ID')}`}
              </span>
            </label>
          ))}
        </div>
      </div>

      <!-- Jumlah tiket -->
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-2">Jumlah Tiket</label>
        <select id="quantity" name="quantity" class="w-full bg-dark-800 border border-dark-600/50 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-brand-500 transition-colors">
          {[1,2,3,4,5].map(n => <option value={n}>{n} tiket</option>)}
        </select>
      </div>

      <!-- Data pembeli -->
      <div class="grid grid-cols-1 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Nama Lengkap</label>
          <input type="text" name="buyer_name" required placeholder="Nama sesuai KTP"
            class="w-full bg-dark-800 border border-dark-600/50 rounded-xl px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:border-brand-500 transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Email</label>
          <input type="email" name="buyer_email" required placeholder="email@kamu.com"
            class="w-full bg-dark-800 border border-dark-600/50 rounded-xl px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:border-brand-500 transition-colors" />
          <p class="text-gray-600 text-xs mt-1">E-ticket akan dikirim ke email ini</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Nomor HP / WhatsApp</label>
          <input type="tel" name="buyer_phone" required placeholder="08xxxxxxxxxx"
            class="w-full bg-dark-800 border border-dark-600/50 rounded-xl px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:border-brand-500 transition-colors" />
        </div>
      </div>

      <!-- Order summary -->
      <div class="bg-dark-800 border border-dark-600/50 rounded-xl p-5">
        <h3 class="font-semibold text-white mb-4">Ringkasan Order</h3>
        <div class="flex justify-between text-sm text-gray-400 mb-2">
          <span id="summaryType">—</span>
          <span id="summaryQty">—</span>
        </div>
        <div class="flex justify-between font-bold text-white border-t border-dark-600/50 pt-3 mt-3">
          <span>Total</span>
          <span id="summaryTotal" class="text-brand-400 font-mono">—</span>
        </div>
      </div>

      <!-- Submit -->
      <button type="submit" id="submitBtn"
        class="w-full bg-brand-600 hover:bg-brand-500 text-white font-bold py-4 rounded-xl transition-all duration-200 hover:scale-[1.02] disabled:opacity-50 disabled:cursor-not-allowed disabled:scale-100">
        Lanjut ke Pembayaran →
      </button>

      <p class="text-gray-600 text-xs text-center">
        Dengan membeli tiket, kamu menyetujui syarat & ketentuan yang berlaku.
      </p>
    </form>

    <!-- Error message -->
    <div id="errorMsg" class="hidden mt-4 bg-red-900/30 border border-red-700/50 rounded-xl p-4 text-red-300 text-sm"></div>
  </div>
</Base>

<script define:vars={{ availableTypes, eventSlug: slug }}>
  // Update order summary saat input berubah
  function updateSummary() {
    const selected = document.querySelector('input[name="ticket_type_id"]:checked');
    const qty = parseInt(document.getElementById('quantity').value);
    if (!selected) return;

    const price = parseInt(selected.dataset.price);
    const name = selected.dataset.name;
    const total = price * qty;

    document.getElementById('summaryType').textContent = name;
    document.getElementById('summaryQty').textContent = `${qty} × Rp ${price.toLocaleString('id-ID')}`;
    document.getElementById('summaryTotal').textContent =
      total === 0 ? 'Gratis' : `Rp ${total.toLocaleString('id-ID')}`;
  }

  document.querySelectorAll('input[name="ticket_type_id"]').forEach(el => el.addEventListener('change', updateSummary));
  document.getElementById('quantity').addEventListener('change', updateSummary);
  updateSummary();

  // Submit form
  document.getElementById('ticketForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    const errorEl = document.getElementById('errorMsg');
    btn.disabled = true;
    btn.textContent = 'Memproses...';
    errorEl.classList.add('hidden');

    const formData = new FormData(e.target);
    const selected = document.querySelector('input[name="ticket_type_id"]:checked');

    const payload = {
      event_slug: eventSlug,
      ticket_type_id: formData.get('ticket_type_id'),
      ticket_type_name: selected.dataset.name,
      quantity: parseInt(formData.get('quantity')),
      buyer_name: formData.get('buyer_name'),
      buyer_email: formData.get('buyer_email'),
      buyer_phone: formData.get('buyer_phone'),
    };

    try {
      const res = await fetch('/api/orders/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();

      if (!res.ok) throw new Error(data.message || 'Terjadi kesalahan');

      // Redirect ke halaman pembayaran
      window.location.href = `/orders/${data.order_code}/payment`;
    } catch (err) {
      errorEl.textContent = err.message;
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Lanjut ke Pembayaran →';
    }
  });
</script>
